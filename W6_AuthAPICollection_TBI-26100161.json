{
  "info": {
    "name": "W6 Auth API Collection - TBI-26100161",
    "description": "Complete authentication API collection including register, login, OAuth, protected routes, and rate limiting tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
