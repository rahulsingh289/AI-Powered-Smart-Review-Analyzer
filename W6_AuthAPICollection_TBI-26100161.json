                  "pm.test('Response contains stats', function() {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('totalReviews');",
                  "    pm.expect(jsonData).to.have.property('positiveCount');",
                  "    pm.expect(jsonData).to.have.property('negativeCount');",
                  "    pm.expect(jsonData).to.have.property('topThemes');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
